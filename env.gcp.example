# GCP（Cloud SQL + GCE + docker-compose.gcp.yml）向けの例。
# 使い方: cp env.gcp.example .env し、プレースホルダを置き換える。
# ローカル開発用の env.example とは別ファイルにして、本番値を混ぜないこと。

# ==============================================
# Django（本番）
# ==============================================
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com

# ==============================================
# Cloud SQL（PostgreSQL）
# ==============================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=my_ads_platform
DB_USER=
DB_PASSWORD=
# Cloud SQL のプライベート IP、またはプロキシ経由のホスト
DB_HOST=
DB_PORT=5432
# パブリック IP で接続する場合など SSL が必要なときに設定（例: require）
# プライベート IP のみで接続し SSL を使わない場合は空のまま
DB_SSLMODE=

# ==============================================
# Redis（同一 VM 上のコンテナ）
# ==============================================
REDIS_URL=redis://redis:6379/0

# ==============================================
# CORS / フロント
# ==============================================
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
FRONTEND_URL=https://example.com

# ==============================================
# JWT（本番用に必ず強い値へ）
# ==============================================
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================
# 外部連携（Secret Manager に置くことを推奨）
# ==============================================
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_REDIRECT_URI=https://example.com/api/accounts/box-accounts/oauth_callback/

# ==============================================
# 監視（推奨）
# ==============================================
SENTRY_DSN=
